# Required only for AI extraction and MCP-backed search.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional remote Streamable HTTP MCP server that exposes authorized listing tools.
# Do not point this to an unlicensed scraper.
MCP_LISTINGS_SERVER_URL=
MCP_LISTINGS_SERVER_LABEL=listings
MCP_LISTINGS_AUTHORIZATION=

# The app uses mock listings when the MCP server is not configured.
USE_MOCK_LISTINGS=true

# Google sign-in (the only supported sign-in method) and per-user Google
# Drive document storage. Create an OAuth client at
# https://console.cloud.google.com/apis/credentials, enable the
# "Google Drive API" for the project, and add the
# https://www.googleapis.com/auth/drive.file scope on the OAuth consent
# screen. Add http://localhost:3000/api/auth/callback/google (and your
# production URL equivalent) as an authorized redirect URI.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Generate with: npx auth secret
AUTH_SECRET=
# Required outside Vercel (self-hosted/Docker) - must match the deployed origin.
AUTH_URL=http://localhost:3000

# Saved searches + daily "new matches" email alerts.
# Postgres (Vercel dashboard -> Storage -> Create Database -> Postgres, then
# `vercel env pull .env.local` to sync these locally). Run db/schema.sql once
# against the database before using this feature.
DATABASE_URL=
# Resend (https://resend.com) API key used to send the daily alert email.
# The default sender below works without verifying your own domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL="HomeBuy Agent <onboarding@resend.dev>"
# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` when it
# triggers /api/cron/daily-search-alerts. Required - requests without a
# matching value are rejected. Generate with: openssl rand -hex 24
CRON_SECRET=

